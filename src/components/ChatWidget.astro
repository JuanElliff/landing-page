<button id="chat-btn" aria-label="Abrir chat">💬</button>

<div id="chat-window" role="dialog" aria-label="Chat con Juan Cruz">
  <div class="chat-header">
    <div class="chat-avatar">JC</div>
    <div class="chat-header-info">
      <div class="chat-header-name">Juan Cruz Elliff</div>
      <div class="chat-header-sub">Asistente · responde al instante</div>
    </div>
    <button class="chat-close" id="chat-close" aria-label="Cerrar chat">✕</button>
  </div>
  <div class="chat-messages" id="chat-messages"></div>
  <div class="chat-input-area">
    <textarea
      class="chat-input"
      id="chat-input"
      placeholder="Escribí tu consulta..."
      rows="1"
    ></textarea>
    <button class="chat-send" id="chat-send" aria-label="Enviar">→</button>
  </div>
</div>
